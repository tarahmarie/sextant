cytoscape-layouts/*
py4cytoscape.log

# Temporary csv files
**/*.csv

# Logs
notebooks/logs/*
notebooks/logs/py4cytoscape.log

# Bash variables Python can use
.current_project
.alignments_file_name

# Lock files
*.lock
.ipynb_checkpoints/

# Shelley-Lovelace corpus splits
